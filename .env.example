# Connexion Supabase (lecture seule via RLS).
# Ces valeurs sont publiques par design (clé anon) — OK de les committer/exposer côté client.
# Copie ce fichier en `.env` et remplis avec les valeurs de ton projet Supabase.

# URL du projet, ex: https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Clé "anon public" (Settings > API dans le dashboard Supabase)
VITE_SUPABASE_ANON_KEY=
